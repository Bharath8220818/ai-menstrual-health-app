# Femi-Friendly Configuration
# Copy this to .env and update with your values

# Backend Configuration
API_BASE_URL=http://127.0.0.1:8000
API_TIMEOUT_SECONDS=30

# Flask/FastAPI Server
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FASTAPI_ENV=development
FASTAPI_RELOAD=true

# Database (if using external DB in future)
DATABASE_URL=sqlite:///./femi_friendly.db

# MongoDB (product recommendations)
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=femi_friendly
MONGO_PRODUCT_COLLECTION=products

# Live Product APIs
PRODUCT_API_PROVIDER=serpapi
PRODUCT_SEARCH_COUNTRY=us
PRODUCT_SEARCH_LANGUAGE=en
SERPAPI_API_KEY=
RAPIDAPI_KEY=
RAPIDAPI_HOST=
RAPIDAPI_ENDPOINT=https://real-time-product-search.p.rapidapi.com/search

# Product Recommendation ML Model
PRODUCT_ML_MODEL_PATH=ai_model/product_category_rf.joblib

# Authentication
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_EXPIRATION_HOURS=24

# Notifications
ENABLE_EMAIL_NOTIFICATIONS=false
ENABLE_SMS_NOTIFICATIONS=false

# Firebase (optional)
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
FIREBASE_DATABASE_URL=

# Machine Learning
MODEL_PATH=ai_model/model.pkl
ENABLE_AI_PREDICTIONS=true
AI_CONFIDENCE_THRESHOLD=0.5

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/femi_friendly.log

# Flutter App Configuration
FLUTTER_ENVIRONMENT=development
ANDROID_EMULATOR_IP=10.0.2.2
DEVICE_IP=localhost
